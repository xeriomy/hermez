<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Hermex base theme — dark only for now.
        Uses Material3 via Compose — the Activity itself only needs a
        NoActionBar Material3 parent so the status bar / window
        background behave on API 24+.

        windowLightStatusBar is FALSE so status bar icons are white
        (suitable for the dark Compose theme applied in MainActivity).
        windowBackground is black so there's no white flash on launch.
    -->
    <style name="Theme.Hermex" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
